INSERT INTO FRAGMENTENTRY VALUES(1,0,'5bada1b4-8fe7-8416-8404-016423298b59','5bada1b4-8fe7-8416-8404-016423298b59',-806,'1',806,69131,16796623585306,20122,'Clarity Admin','2025-10-03 13:39:36.000000','2025-11-02 13:59:52.000000',69358,'header-main','Commerce Header Main','#commerce-header-main {\u000a\u0009background-color: var(--white);\u000a\u0009border-bottom: 1px solid var(--gray-300);\u000a}\u000a\u000a#commerce-header-main .cart-root .mini-cart {\u000a\u0009height: 35px;\u000a\u0009transition:\u000a\u0009\u0009height 0ms ease-out,\u000a\u0009\u0009width 0ms ease-out,\u000a\u0009\u0009top 0ms ease-out;\u000a\u0009transition-delay: 200ms !important;\u000a\u0009width: 35px;\u000a}\u000a\u000a#commerce-header-main .cart-root .mini-cart.is-open {\u000a\u0009height: calc(\u000a\u0009\u0009100vh - var(--control-menu-container-height, 0px) - var(--commerce-header-user-height) -\u000a\u0009\u000910px\u000a\u0009);\u000a}\u000a\u000a#commerce-header-main .cart-root .mini-cart .mini-cart-overlay {\u000a\u0009height: 100%;\u000a\u0009position: relative;\u000a\u0009top: 0;\u000a\u0009transition: top 0ms ease-out;\u000a\u0009transition-delay: 200ms;\u000a\u0009width: 35px;\u000a}\u000a\u000a#commerce-header-main .cart-root .mini-cart.is-open .mini-cart-overlay {\u000a\u0009height: calc(100vh - var(--control-menu-container-height, 0px));\u000a\u0009position: fixed;\u000a\u0009top: var(--control-menu-container-height, 0px);\u000a\u0009transition-delay: 0ms;\u000a\u0009width: 100vw;\u000a}\u000a\u000a#commerce-header-main .cart-root .mini-cart .mini-cart-wrapper {\u000a\u0009height: calc(100vh - var(--control-menu-container-height, 0px));\u000a\u0009top: calc(-1 * var(--commerce-header-user-height) - 10px);\u000a}\u000a\u000a#commerce-header-main .cart-root .mini-cart.is-open .mini-cart-wrapper {\u000a\u0009background-color: #fff;\u000a\u0009height: calc(100vh - var(--control-menu-container-height, 0px));\u000a\u0009top: calc(-1 * var(--commerce-header-user-height) - 10px);\u000a\u0009transform: translate3d(calc(100vw / 2 - 612px), 0, 0);\u000a\u0009z-index: 1000;\u000a}\u000a\u000a#commerce-header-main .cart-root .mini-cart .mini-cart-opener {\u000a\u0009height: 35px;\u000a\u0009width: 35px;\u000a}\u000a\u000a#commerce-header-search .portlet-search-bar {\u000a\u0009max-width: 400px;\u000a\u0009width: 65%;\u000a}\u000a\u000a#commerce-header-components {\u000a\u0009min-height: var(--commerce-header-user-height)\u000a}\u000a\u000a@media (min-width: 1920px) {\u000a\u0009#commerce-header-main .mini-cart:not(.is-open) .mini-cart-wrapper {\u000a\u0009\u0009transform: translate3d(50vw, 0, 0);\u000a\u0009}\u000a\u000a\u0009.rtl #commerce-header-main .mini-cart:not(.is-open) .mini-cart-wrapper {\u000a\u0009\u0009transform: translate3d(calc(-1 * 50vw), 0, 0);\u000a\u0009}\u000a}\u000a\u000a#commerce-header-main\u000a.account-selector-root\u000a.btn-account-selector\u000a.sticker-user-icon {\u000a\u0009border-radius: var(--border-radius);\u000a}','<div class="py-2" id="commerce-header-main">\u000a\u0009<div class="container-fluid container-fluid-max-xl">\u000a\u0009\u0009<div class="align-items-center row">\u000a\u0009\u0009\u0009<div class="col-3" id="commerce-header-logo">\u000a\u0009\u0009\u0009\u0009<img alt="" data-lfr-editable-id="commerce-site-main-logo" data-lfr-editable-type="image" src="[resources:site_logo.svg]" />\u000a\u0009\u0009\u0009</div>\u000a\u000a\u0009\u0009\u0009<div class="col-6 d-flex justify-content-center" id="commerce-header-search">\u000a\u0009\u0009\u0009\u0009[#assign preferences = freeMarkerPortletPreferences.getPreferences({"portletSetupPortletDecoratorId": "barebone", "destination": "/search"}) /]\u000a\u000a\u0009\u0009\u0009\u0009[@liferay.search_bar default_preferences="${preferences}" /]\u000a\u0009\u0009\u0009</div>\u000a\u000a\u0009\u0009\u0009<div class="align-items-center col-3 d-flex justify-content-end position-relative" id="commerce-header-components">\u000a\u0009\u0009\u0009\u0009[@liferay_commerce_ui["account-selector"] cssClasses="mr-6" /]\u000a\u000a\u0009\u0009\u0009\u0009[@liferay_commerce_ui["mini-cart"] cssClasses="position-absolute sticky-top" /]\u000a\u0009\u0009\u0009</div>\u000a\u0009\u0009</div>\u000a\u0009</div>\u000a</div>','/**\u000a * SPDX-FileCopyrightText: (c) 2000 Liferay, Inc. https://liferay.com\u000a * SPDX-License-Identifier: LGPL-2.1-or-later OR LicenseRef-Liferay-DXP-EULA-2.0.0-2023-06\u000a */','0','','code',0,'0','0',0,'',NULL,0,20122,'Clarity Admin','2025-11-02 13:59:52.000000')
