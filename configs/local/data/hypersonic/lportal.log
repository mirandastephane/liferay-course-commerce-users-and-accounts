\u0009\u0009\u0009displayType="link"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009onClick="Liferay.Search.FacetUtil.changeSelection(event);"\u000a\u0009\u0009\u0009\u0009\u0009\u0009>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009<#if entry.isSelected()>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009<strong>${htmlUtil.escape(entry.getBucketText())}</strong>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009<#else>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009${htmlUtil.escape(entry.getBucketText())}\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009</#if>\u000a\u0009\u0009\u0009\u0009\u0009\u0009</@clay.button>\u000a\u0009\u0009\u0009\u0009\u0009</span>\u000a\u0009\u0009\u0009\u0009</#list>\u000a\u0009\u0009\u0009</#if>\u000a\u0009\u0009</ul>\u000a\u0009</@>\u000a</@>',0,20095,NULL,'2024-05-13 14:37:50.723000')
