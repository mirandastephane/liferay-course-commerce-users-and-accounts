": "string",\u000a\u0009\u0009\u0009\u0009\u0009"defaultValue": "nm",\u000a\u0009\u0009\u0009\u0009\u0009"label": "size",\u000a\u0009\u0009\u0009\u0009\u0009"name": "buttonSize",\u000a\u0009\u0009\u0009\u0009\u0009"type": "select",\u000a\u0009\u0009\u0009\u0009\u0009"typeOptions": {\u000a\u0009\u0009\u0009\u0009\u0009\u0009"validValues": [\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009{\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009"label": "small",\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009"value": "sm"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009},\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009{\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009"label": "normal",\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009"value": "nm"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009},\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009{\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009"label": "large",\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009"value": "lg"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009}\u000a\u0009\u0009\u0009\u0009\u0009\u0009]\u000a\u0009\u0009\u0009\u0009\u0009}\u000a\u0009\u0009\u0009\u0009}\u000a\u0009\u0009\u0009]\u000a\u0009\u0009}\u000a\u0009]\u000a}','0','{"com.liferay.fragment.entry.processor.editable.EditableFragmentEntryProcessor":{"previous-button-text":{"defaultValue":"\n\t\t\t\tPrevious\n\t\t\t","config":{}}},"com.liferay.fragment.entry.processor.freemarker.FreeMarkerFragmentEntryProcessor":{"buttonType":"primary","submittedEntryStatus":"2","type":"previous","buttonSize":"nm"}}','vdvk',0,'INPUTS-submit-button',3,'2026-01-14 17:18:48.589000',NULL,'d0c31efd-a019-df7f-5d79-4d592344c1f3')
