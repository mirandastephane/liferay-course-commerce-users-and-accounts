INSERT INTO FRAGMENTENTRY VALUES(1,0,'b7cd1d26-235f-1593-41ab-1664d59e650f','b7cd1d26-235f-1593-41ab-1664d59e650f',-810,'1',810,69131,16796623585306,20122,'Clarity Admin','2025-10-03 13:39:36.000000','2025-11-02 13:59:52.000000',69358,'header-user','Commerce Header User','#commerce-header-user {\u000a\u0009background-color: var(--white);\u000a\u0009border-bottom: 1px solid var(--gray-300);\u000a}\u000a\u000a.currency-selector-container .dropdown-menu-content.dropdown-menu,\u000a.language-selector-container .dropdown-menu-content.dropdown-menu {\u000a\u0009max-height: fit-content;\u000a\u0009min-width: 288px;\u000a}\u000a\u000a.language-selector-container .dropdown-menu.show {\u000a\u0009z-index: 1021;\u000a}\u000a\u000a.currency-selector-container\u000a\u0009.currency-dropdown-list-container\u000a\u0009.currency-dropdown-list\u000a\u0009ul,\u000a.language-selector-container\u000a\u0009.language-dropdown-list-container\u000a\u0009.language-dropdown-list\u000a\u0009ul {\u000a\u0009padding-inline-start: 0;\u000a}\u000a\u000a.currency-selector-container\u000a\u0009.currency-dropdown-list-container\u000a\u0009.currency-dropdown-list\u000a\u0009.currency-nav-item,\u000a.language-selector-container\u000a\u0009.language-dropdown-list-container\u000a\u0009.language-dropdown-list\u000a\u0009.language-nav-item {\u000a\u0009align-items: center;\u000a\u0009border-radius: var(--border-radius-xs);\u000a\u0009display: flex;\u000a\u0009font-weight: var(--font-weight-semi-bold);\u000a\u0009text-align: left;\u000a}\u000a\u000a.currency-selector-container\u000a\u0009.currency-dropdown-list-container\u000a\u0009.currency-dropdown-list\u000a\u0009.currency-nav-item:active,\u000a.currency-selector-container\u000a\u0009.currency-dropdown-list-container\u000a\u0009.currency-dropdown-list\u000a\u0009.currency-nav-item:focus,\u000a.currency-selector-container\u000a\u0009.currency-dropdown-list-container\u000a\u0009.currency-dropdown-list\u000a\u0009.currency-nav-item:hover,\u000a.language-sel