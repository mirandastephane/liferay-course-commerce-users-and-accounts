ector-container\u000a\u0009.language-dropdown-list-container\u000a\u0009.language-dropdown-list\u000a\u0009.language-nav-item:active,\u000a.language-selector-container\u000a\u0009.language-dropdown-list-container\u000a\u0009.language-dropdown-list\u000a\u0009.language-nav-item:focus,\u000a.language-selector-container\u000a\u0009.language-dropdown-list-container\u000a\u0009.language-dropdown-list\u000a\u0009.language-nav-item:hover {\u000a\u0009background-color: #edf3fe !important;\u000a}\u000a\u000a.currency-selector-container\u000a\u0009.currency-dropdown-list-container\u000a\u0009.currency-dropdown-list\u000a\u0009.currency-nav-item\u000a\u0009.currency-entry-long-text,\u000a.language-selector-container\u000a\u0009.language-dropdown-list-container\u000a\u0009.language-dropdown-list\u000a\u0009.language-nav-item\u000a\u0009.language-entry-long-text {\u000a\u0009color: var(--black);\u000a\u0009padding: 0.75rem 0.75rem 0.75rem 3.5rem !important;\u000a\u0009width: 100%;\u000a}\u000a\u000a.currency-selector-container\u000a\u0009.currency-dropdown-list-container\u000a\u0009.currency-dropdown-list\u000a\u0009.currency-nav-item\u000a\u0009.selected-icon,\u000a.language-selector-container\u000a\u0009.language-dropdown-list-container\u000a\u0009.language-dropdown-list\u000a\u0009.language-nav-item\u000a\u0009.selected-icon {\u000a\u0009height: 16px;\u000a\u0009width: auto !important;\u000a}\u000a\u000a.currency-selector-container\u000a\u0009.currency-dropdown-list-container\u000a\u0009.currency-dropdown-list\u000a\u0009.currency-nav-item\u000a\u0009.selected-icon\u000a\u0009svg,\u000a.language-selector-container\u000a\u0009.language-dropdown-list-container\u000a\u0009.language-dropdown-list\u000a\u0009.language-nav-item\u000a\u0009.selected-icon\u000a\u0009svg {\u000a\u0009height: 100%;\u000a\u0009width: 100%;\u000a}\u000a\u000a.currency-selector-container\u000a\u0009.currency-dropdown-list-container\u000a\u0009.currency-dropdown-list\u000a\u0009.currency-nav-item\u000a\u0009.currency-entry-long-text:active,\u000a.currency-selector-container\u000a\u0009.currency-dropdown-list-container\u000a\u0009.currency-dropdown-list\u000a\u0009.currency-nav-item\u000a\u0009.currency-entry-long-text:focus,\u000a.currency-selector-container\u000a\u0009.currency-dropdown-list-container\u000a\u0009.currency-dropdown-list\u000a\u0009.currency-nav-item\u000a\u0009.currency-entry-long-text:hover,\u000a.language-selector-container\u000a\u0009.language-dropdown-list-container\u000a\u0009.language-dropdown-list\u000a\u0009.language-nav-item\u000a\u0009.language-entry-long-text:active,\u000a.language-selector-container\u000a\u0009.language-dropdown-list-container\u000a\u0009.language-dropdown-list\u000a\u0009.language-nav-item\u000a\u0009.language-entry-long-text:focus,\u000a.language-selector-container\u000a\u0009.language-dropdown-list-container\u000a\u0009.language-dropdown-list\u000a\u0009.language-nav-item\u000a\u0009.language-entry-long-text:hover {\u000a\u0009color: var(--black);\u000a\u0009text-decoration: none;\u000a}\u000a\u000a.currency-selector-container\u000a\u0009.currency-dropdown-list-container\u000a\u0009.currency-dropdown-list\u000a\u0009.currency-nav-item.selected,\u000a.language-selector-container\u000a\u0009.language-dropdown-list-container\u000a\u0009.language-dropdown-list\u000a\u0009.language-nav-item.selected {\u000a\u0009padding-left: 1.5rem;\u000a}\u000a\u000a.currency-selector-container\u000a\u0009.currency-dropdown-list-container\u000a\u0009.currency-dropdown-list\u000a\u0009.currency-nav-item.selected:before,\u000a.language-selector-container\u000a\u0009.language-dropdown-list-container\u000a\u0009.language-dropdown-list\u000a\u0009.language-nav-item.selected:before {\u000a\u0009margin: 0 1rem;\u000a}\u000a\u000a.currency-selector-container\u000a\u0009.currency-dropdown-list-container\u000a\u0009.currency-dropdown-list\u000a\u0009.currency-nav-item.selected\u000a\u0009.currency-entry-long-text,\u000a.language-selector-container\u000a\u0009.language-dropdown-list-container\u000a\u0009.language-dropdown-list\u000a\u0009.language-nav-item.selected\u000a\u0009.language-entry-long-text {\u000a\u0009padding-left: 1rem !important;\u000a}\u000a\u000a.currency-selector-container .currency-selector,\u000a.language-selector-container .language-selector {\u000a\u0009background: inherit;\u000a\u0009border: none;\u000a\u0009border-radius: var(--border-radius-sm);\u000a\u0009color: var(--gray-600);\u000a\u0009cursor: pointer;\u000a\u0009display: inline-block;\u000a\u0009font-weight: bolder;\u000a}\u000a\u000a.language-selector-container .language-selector svg {\u000a\u0009height: 1.5rem;\u000a\u0009margin-right: 0.25rem;\u000a\u0009padding-bottom: 0.1rem;\u000a\u0009padding-right: 0.1rem;\u000a\u0009transform: translateY(1px) scale(0.75);\u000a\u0009width: 1.5rem;\u000a}\u000a\u000a.currency-selector-container\u000a\u0009.currency-selector[aria-expanded=''true'']\u000a\u0009.currency-caret-icon\u000a\u0009svg,\u000a.language-selector-container\u000a\u0009.language-selector[aria-expanded=''true'']\u000a\u0009.language-caret-icon\u000a\u0009svg {\u000a\u0009transform: rotate(180deg);\u000a}\u000a\u000a.currency-selector-container .currency-selector:hover,\u000a.language-selector-container .language-selector:hover {\u000a\u0009background-color: var(--gray-200) !important;\u000a}\u000a\u000a.personal-menu-dropdown .sticker-lg {\u000a\u0009font-size: 0.825rem;\u000a\u0009height: 1.5rem;\u000a\u0009width: 1.5rem;\u000a}\u000a\u000a.portlet {\u000a\u0009margin-bottom: 0 !important;\u000a}','<div class="py-1" id="commerce-header-user">\u000a\u0009<div class="align-items-center container-fluid container-fluid-max-xl d-flex justify-content-end">\u000a\u0009\u0009[#if configuration.showLanguageMenu]\u000a\u0009\u0009\u0009<div class="language-selector-container ml-2">\u000a\u0009\u0009\u0009\u0009<button class="d-flex language language-selector py-1" data-toggle="liferay-dropdown" id="language-selector-id" tabindex="-1">\u000a\u0009\u0009\u0009\u0009\u0009<span class="d-inline-block language-selector-globe-icon">\u000a\u0009\u0009\u0009\u0009\u0009\u0009[@clay["icon"] symbol="globe-lines" /]\u000a\u0009\u0009\u0009\u0009\u0009</span>\u000a\u0009\u0009\u0009\u0009\u0009<span class="d-inline-block language-selector-text text-nowrap">\u000a\u0009\u0009\u0009\u0009\u0009\u0009[#assign current_locale = locale /]\u000a\u000a\u0009\u0009\u0009\u0009\u0009\u0009[#if current_locale?has_content]\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009[#assign current_locale = locale[0..1]\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009+ " (" + locale[3..4] + ")"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009/]\u000a\u0009\u0009\u0009\u0009\u0009\u0009[/#if]\u000a\u000a\u0009\u0009\u0009\u0009\u0009\u0009${current_locale?upper_case}\u000a\u0009\u0009\u0009\u0009\u0009</span>\u000a\u0009\u0009\u0009\u0009</button>\u000a\u000a\u0009\u0009\u0009\u0009<div aria-labelledby="language-selector-id" class="dropdown-menu dropdown-menu-content">\u000a\u0009\u0009\u0009\u0009\u0009<div class="language-dropdown-list-container">\u000a\u0009\u0009\u0009\u0009\u0009\u0009<div class="language-dropdown-list">\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009<ul>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009[#if entries?has_content]\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009[#list entries as curLanguage]\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009<li class="${(curLanguage.isSelected())?then(''selected'', '''')} language-nav-item">\u000a\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009[#if curLanguage.isSelected()]\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009<div class="d-inline-block selected-icon">\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009[@clay["icon"] symbol="check" /]\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009</div>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009[/#if]\u000a\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009[#assign curLanguageLabel = curLanguage.longDisplayName?capitalize /]\u000a\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009[#if curLanguage.shortDisplayName="en" | curLanguage.shortDisplayName="pt"]\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009[#assign\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009curLanguageLocale = curLanguage.getLocale()\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009curLanguageLabel = curLanguageLabel + " (" + curLanguageLocale.getDisplayCountry(curLanguageLocale) + ")"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009/]\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009[/#if]\u000a\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009[@clay["link"]\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009cssClass="language-entry-long-text"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009href=curLanguage.getURL()\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009label=curLanguageLabel\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009lang=curLanguage.getW3cLanguageId()\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009localizeLabel=false\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009/]\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009</li>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009[/#list]\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009[/#if]\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009</ul>\u000a\u0009\u0009\u0009\u0009\u0009\u0009</div>\u000a\u0009\u0009\u0009\u0009\u0009</div>\u000a\u0009\u0009\u0009\u0009</div>\u000a\u0009\u0009\u0009</div>\u000a\u0009\u0009[/#if]\u000a\u000a\u0009\u0009[#if configuration.showCurrencyMenu]\u000a\u0009\u0009\u0009<div class="currency-selector-container ml-2">\u000a\u0009\u0009\u0009\u0009<button class="currency currency-selector d-flex py-2" data-toggle="liferay-dropdown" id="currency-selector-id" tabindex="-1">\u000a\u0009\u0009\u0009\u0009\u0009<span class="currency-selector-symbol d-inline-block"></span>\u000a\u000a\u0009\u0009\u0009\u0009\u0009<span class="currency-selector-text d-inline-block text-nowrap"></span>\u000a\u0009\u0009\u0009\u0009</button>\u000a\u000a\u0009\u0009\u0009\u0009<div aria-labelledby="currency-selector-id" class="dropdown-menu dropdown-menu-content">\u000a\u0009\u0009\u0009\u0009\u0009<div class="currency-dropdown-list-container">\u000a\u0009\u0009\u0009\u0009\u0009\u0009<div class="currency-dropdown-list">\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009<ul></ul>\u000a\u0009\u0009\u0009\u0009\u0009\u0009</div>\u000a\u0009\u0009\u0009\u0009\u0009</div>\u000a\u0009\u0009\u0009\u0009</div>\u000a\u0009\u0009\u0009</div>\u000a\u0009\u0009[/#if]\u000a\u000a\u0009\u0009<div class="border-left ml-2 pl-3">\u000a\u0009\u0009\u0009[@liferay.user_personal_bar /]\u000a\u0009\u0009</div>\u000a\u0009</div>\u000a</div>','/**\u000a * SPDX-FileCopyrightText: (c) 2000 Liferay, Inc. https://liferay.com\u000a * SPDX-License-Identifier: LGPL-2.1-or-later OR LicenseRef-Liferay-DXP-EULA-2.0.0-2023-06\u000a */','0','{\u000a\u0009"fieldSets": [\u000a\u0009\u0009{\u000a\u0009\u0009\u0009"fields": [\u000a\u0009\u0009\u0009\u0009{\u000a\u0009\u0009\u0009\u0009\u0009"dataType": "string",\u000a\u0009\u0009\u0009\u0009\u0009"defaultValue": true,\u000a\u0009\u0009\u0009\u0009\u0009"description": "Show Account Menu",\u000a\u0009\u0009\u0009\u0009\u0009"label": "Show Account Menu",\u000a\u0009\u0009\u0009\u0009\u0009"name": "showAccountMenu",\u000a\u0009\u0009\u0009\u0009\u0009"type": "checkbox"\u000a\u0009\u0009\u0009\u0009},\u000a\u0009\u0009\u0009\