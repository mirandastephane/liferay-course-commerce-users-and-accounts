INSERT INTO FRAGMENTENTRY VALUES(0,0,'38940e98-dda8-f6d1-2918-4b3ace46ced9','38940e98-dda8-f6d1-2918-4b3ace46ced9',-804,'1',804,69131,16796623585306,20122,'Clarity Admin','2025-10-03 13:39:36.000000','2025-10-03 13:39:35.000000',69358,'commerce-components-group','Commerce Components Group','#commerce-components-group .cart-root .mini-cart {\u000a\u0009display: contents;\u000a\u0009height: var(--commerce-header-user-height, 0);\u000a\u0009transition:\u000a\u0009\u0009height 0ms ease-out,\u000a\u0009\u0009width 0ms ease-out,\u000a\u0009\u0009top 0ms ease-out;\u000a\u0009transition-delay: 200ms !important;\u000a\u0009width: var(--commerce-header-user-height, 0);\u000a}\u000a\u000a#commerce-components-group .cart-root .mini-cart.is-open {\u000a\u0009height: calc(\u000a\u0009\u0009100vh - var(--control-menu-container-height, 0px) - var(--commerce-header-user-height) -\u000a\u0009\u000912px\u000a\u0009);\u000a}\u000a\u000a#commerce-components-group .cart-root .mini-cart .mini-cart-opener {\u000a\u0009align-items: center;\u000a\u0009display: flex;\u000a\u0009height: 3.25rem;\u000a\u0009justify-content: center;\u000a\u0009position: relative;\u000a\u0009width: 64px;\u000a}\u000a\u000a#commerce-components-group .cart-root .mini-cart .mini-cart-overlay {\u000a\u0009height: 100%;\u000a\u0009position: relative;\u000a\u0009top: 0;\u000a\u0009transition: top 0ms ease-out;\u000a\u0009transition-delay: 200ms;\u000a\u0009width: var(--commerce-header-user-height, 0);\u000a}\u000a\u000a#commerce-components-group .cart-root .mini-cart.is-open .mini-cart-overlay {\u000a\u0009height: calc(100vh - var(--control-menu-container-height, 0px));\u000a\u0009position: fixed;\u000a\u0009top: var(--control-menu-container-height, 0px);\u000a\u0009transform: translate3d(0, 0, 0);\u000a\u0009transition-delay: 0ms;\u000a\u0009width: 100vw;\u000a}\u000a\u000a#commerce-components-group .cart-root .mini-cart .mini-cart-wrapper {\u000a\u0009position: fixed;\u000a\u0009transform: translate3d(600px, 0, 0);\u000a}\u000a\u000a#commerce-components-group .cart-root .mini-cart.is-open .mini-cart-wrapper {\u000a\u0009background-color: var(--white);\u000a\u0009height: calc(100vh - var(--control-menu-container-height, 0px));\u000a\u0009position: fixed;\u000a\u0009top: var(--control-menu-container-height, 0px);\u000a\u0009transform: translate3d(0, 0, 0);\u000a\u0009z-index: 1000;\u000a}\u000a\u000a#commerce-components-group\u000a.account-selector-root\u000a.btn-account-selector\u000a.sticker-user-icon {\u000a\u0009border-radius: var(--border-radius);\u000a}','<div class="align-items-center d-flex justify-content-end position-relative" id="commerce-components-group">\u000a\u0009[@liferay_commerce_ui["account-selector"] cssClasses="mr-2" /]\u000a\u000a\u0009[@liferay_commerce_ui["mini-cart"] /]\u000a</div>','/**\u000a * SPDX-FileCopyrightText: (c) 2000 Liferay, Inc. https://liferay.com\u000a * SPDX-License-Identifier: LGPL-2.1-or-later OR LicenseRef-Liferay-DXP-EULA-2.0.0-2023-06\u000a */','0','','code',0,'0','0',0,'',NULL,0,20122,'Clarity Admin','2025-10-03 13:39:36.000000')
