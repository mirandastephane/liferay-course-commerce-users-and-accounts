INSERT INTO FRAGMENTENTRYLINK VALUES(48,0,'a092bb81-0c8d-5a74-d4dc-7b9b30dcc896',54650,32106,16796623585306,20122,'Clarity Admin','2025-05-07 22:52:52.752000','2026-01-07 19:02:54.199000',54614,0,32344,20031,21,21,'','[#assign type=configuration.type!''submit'']\u000a\u000a[#if configuration.type == "previous"]\u000a\u0009<div class="component-button text-break">\u000a\u0009\u0009<button class="btn btn-${configuration.buttonSize} btn-${configuration.buttonType}" id="fragment-${fragmentEntryLinkNamespace}-form-button" type="button">\u000a\u0009\u0009\u0009<span data-lfr-editable-id="previous-button-text" data-lfr-editable-type="text">\u000a\u0009\u0009\u0009\u0009Previous\u000a\u0009\u0009\u0009</span>\u000a\u0009\u0009</button>\u000a\u0009</div>\u000a[#elseif configuration.type == "next"]\u000a\u0009<div class="component-button text-break">\u000a\u0009\u0009<button class="btn btn-${configuration.buttonSize} btn-${configuration.buttonType}" id="fragment-${fragmentEntryLinkNamespace}-form-button" type="button">\u000a\u0009\u0009\u0009<span data-lfr-editable-id="next-button-text" data-lfr-editable-type="text">\u000a\u0009\u0009\u0009\u0009Next\u000a\u0009\u0009\u0009</span>\u000a\u0009\u0009</button>\u000a\u0009</div>\u000a[#else]\u000a\u0009<div class="component-button text-break">\u000a\u0009\u0009<button class="btn btn-${configuration.buttonSize} btn-${configuration.buttonType}" data-lfr-editable-id="submit-button-text" data-lfr-editable-type="text" id="fragment-${fragmentEntryLinkNamespace}-submit-button" name="status" type="submit" value="${configuration.submittedEntryStatus}">\u000a\u0009\u0009\u0009Submit\u000a\u0009\u0009</button>\u000a\u0009</div>\u000a[/#if]','const button = fragmentElement.querySelector(''button'');\u000a\u000aconst isMultistepButton = fragmentElement.querySelector(\u000a\u0009`#fragment-${fragmentNamespace}-form-button`\u000a);\u000a\u000abutton.addEventListener(''click'', ({target}) => {\u000a\u0009const isEditable =\u000a\u0009\u0009target.hasAttribute(''data-lfr-editable-id'') ||\u000a\u0009\u0009target.hasAttribute(''contenteditable'');\u000a\u000a\u0009if (isEditable && layoutMode === ''edit'') {\u000a\u0009\u0009return;\u000a\u0009}\u000a\u000a\u0009if (isMultistepButton) {\u000a\u0009\u0009Liferay.fire(''formFragment:changeStep'', {\u000a\u0009\u0009\u0009emitter: fragmentElement,\u000a\u0009\u0009\u0009step: configuration.type,\u000a\u0009\u0009});\u000a\u0009}\u000a\u0009else {\u000a\u0009\u0009Liferay.fire(''formFragment:submit'');\u000a\u0009}\u000a});','{\u000a\u0009"fieldSets": [\u000a\u0009\u0009{\u000a\u0009\u0009\u0009"fields": [\u000a\u0009\u0009\u0009\u0009{\u000a\u0009\u0009\u0009\u0009\u0009"dataType": "string",\u000a\u0009\u0009\u0009\u0009\u0009"defaultValue": "submit",\u000a\u0009\u0009\u0009\u0009\u0009"label": "type",\u000a\u0009\u0009\u0009\u0009\u0009"name": "type",\u000a\u0009\u0009\u0009\u0009\u0009"type": "select",\u000a\u0009\u0009\u0009\u0009\u0009"typeOptions": {\u000a\u0009\u0009\u0009\u0009\u0009\u0009"validValues": [\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009{\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009"value": "previous"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009},\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009{\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009"value": "next"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009},\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009{\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009"value": "submit"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009}\u000a\u0009\u0009\u0009\u0009\u0009\u0009]\u000a\u0009\u0009\u0009\u0009\u0009}\u000a\u0009\u0009\u0009\u0009},\u000a\u0009\u0009\u0009\u0009{\u000a\u0009\u0009\u0009\u0009\u0009"dataType": "string",\u000a\u0009\u0009\u0009\u0009\u0009"defaultValue": "approved",\u000a\u0009\u0009\u0009\u0009\u0009"label": "submitted-entry-status",\u000a\u0009\u0009\u0009\u0009\u0009"name": "submittedEntryStatus",\u000a\u0009\u0009\u0009\u0009\u0009"type": "select",\u000a\u0009\u0009\u0009\u0009\u0009"typeOptions": {\u000a\u0009\u0009\u0009\u0009\u0009\u0009"validValues": [\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009{\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009"label": "approved",\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009"value": "0"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009},\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009{\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009"label": "draft",\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009"value": "2"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009}\u000a\u0009\u0009\u0009\u0009\u0009\u0009]\u000a\u0009\u0009\u0009\u0009\u0009}\u000a\u0009\u0009\u0009\u0009},\u000a\u0009\u0009\u0009\u0009{\u000a\u0009\u0009\u0009\u0009\u0009"dataType": "string",\u000a\u0009\u0009\u0009\u0009\u0009"defaultValue": "primary",\u000a\u0009\u0009\u0009\u0009\u0009"label": "style",\u000a\u0009\u0009\u0009\u0009\u0009"name": "buttonType",\u000a\u0009\u0009\u0009\u0009\u0009"type": "select",\u000a\u0009\u0009\u0009\u0009\u0009"typeOptions": {\u000a\u0009\u0009\u0009\u0009\u0009\u0009"validValues": [\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009{\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009"value": "primary"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009},\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009{\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009"value": "secondary"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009},\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009{\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009"value": "outline-primary"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009},\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009{\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009"value": "outline-secondary"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009}\u000a\u0009\u0009\u0009\u0009\u0009\u0009]\u000a\u0009\u0009\u0009\u0009\u0009}\u000a\u0009\u0009\u0009\u0009},\u000a\u0009\u0009\u0009\u0009{\u000a\u0009\u0009\u0009\u0009\u0009"dataType": "string",\u000a\u0009\u0009\u0009\u0009\u0009"defaultValue": "nm",\u000a\u0009\u0009\u0009\u0009\u0009"label": "size",\u000a\u0009\u0009\u0009\u0009\u0009"name": "buttonSize",\u000a\u0009\u0009\u0009\u0009\u0009"type": "select",\u000a\u0009\u0009\u0009\u0009\u0009"typeOptions": {\u000a\u0009\u0009\u0009\u0009\u0009\u0009"validValues": [\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009{\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009"label": "small",\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009"value": "sm"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009},\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009{\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009"label": "normal",\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009"value": "nm"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009},\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009{\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009"label": "large",\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009"value": "lg"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009}\u000a\u0009\u0009\u0009\u0009\u0009\u0009]\u000a\u0009\u0009\u0009\u0009\u0009}\u000a\u0009\u0009\u0009\u0009}\u000a\u0009\u0009\u0009]\u000a\u0009\u0009}\u000a\u0009]\u000a}','0','{"com.liferay.fragment.entry.processor.editable.EditableFragmentEntryProcessor":{"next-button-text":{"defaultValue":"\n\t\t\t\tNext\n\t\t\t","config":{}}},"com.liferay.fragment.entry.processor.freemarker.FreeMarkerFragmentEntryProcessor":{"buttonType":"primary","submittedEntryStatus":"2","type":"next","buttonSize":"nm"}}','pftj',0,'INPUTS-submit-button',3,'2026-01-07 19:02:54.199000',NULL,'a092bb81-0c8d-5a74-d4dc-7b9b30dcc896')
