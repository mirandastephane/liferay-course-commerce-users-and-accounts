INSERT INTO FRAGMENTENTRYLINK VALUES(48,0,'8c14ae6c-91dc-c708-c4f2-9225adc648ab','8c14ae6c-91dc-c708-c4f2-9225adc648ab',75348,32106,16796623585306,20122,'Clarity Admin','2025-10-16 13:55:30.000000','2026-03-19 16:19:04.207000','93a4943f-2136-95e3-3b48-82c7a78b94ee','','',32282,20031,17,17,'body.has-edit-mode-menu .mini-cart-fragment {\u000a\u0009min-height: 64px;\u000a}\u000a\u000abody.has-edit-mode-menu\u000a\u0009.mini-cart-fragment\u000a\u0009.mini-cart.is-open\u000a\u0009.mini-cart-overlay,\u000abody.has-edit-mode-menu\u000a\u0009.mini-cart-fragment\u000a\u0009.mini-cart.is-open\u000a\u0009.mini-cart-wrapper {\u000a\u0009display: none;\u000a}\u000a\u000a.mini-cart-fragment {\u000a\u0009position: relative;\u000a}\u000a\u000a.mini-cart-fragment .mini-cart.is-open .mini-cart-overlay,\u000a.mini-cart-fragment .mini-cart.is-open .mini-cart-wrapper {\u000a\u0009position: fixed;\u000a}\u000a\u000a.mini-cart-fragment .mini-cart:not(.is-open) .mini-cart-overlay,\u000a.mini-cart-fragment .mini-cart:not(.is-open) .mini-cart-wrapper {\u000a\u0009display: none;\u000a}','<div class="mini-cart-fragment" [#if configuration.iconColor?has_content]style="--mini-cart-icon-color: ${configuration.iconColor};"[/#if]>\u000a\u0009[@liferay_commerce_ui["mini-cart"]\u000a\u0009\u0009displayTotalItemsQuantity=configuration.displayTotalItemsQuantity\u000a\u0009\u0009spritemap="${themeDisplay.getPathThemeImages()}/clay/icons.svg"\u000a\u0009\u0009toggleable=true\u000a\u0009/]\u000a</div>','/**\u000a * SPDX-FileCopyrightText: (c) 2000 Liferay, Inc. https://liferay.com\u000a * SPDX-License-Identifier: LGPL-2.1-or-later OR LicenseRef-Liferay-DXP-EULA-2.0.0-2023-06\u000a */','{\u000a\u0009"fieldSets": [\u000a\u0009\u0009{\u000a\u0009\u0009\u0009"fields": [\u000a\u0009\u0009\u0009\u0009{\u000a\u0009\u0009\u0009\u0009\u0009"defaultValue": "var(--gray-600)",\u000a\u0009\u0009\u0009\u0009\u0009"label": "icon-color",\u000a\u0009\u0009\u0009\u0009\u0009"name": "iconColor",\u000a\u0009\u0009\u0009\u0009\u0009"type": "colorPicker"\u000a\u0009\u0009\u0009\u0009},\u000a\u0009\u0009\u0009\u0009{\u000a\u0009\u0009\u0009\u0009\u0009"defaultValue": true,\u000a\u0009\u0009\u0009\u0009\u0009"label": "mini-cart-display-total-items-count",\u000a\u0009\u0009\u0009\u0009\u0009"name": "displayTotalItemsQuantity",\u000a\u0009\u0009\u0009\u0009\u0009"type": "checkbox"\u000a\u0009\u0009\u0009\u0009}\u000a\u0009\u0009\u0009]\u000a\u0009\u0009}\u000a\u0009]\u000a}','0','{"com.liferay.fragment.entry.processor.freemarker.FreeMarkerFragmentEntryProcessor":{"displayTotalItemsQuantity":true,"iconColor":"var(--gray-600)"}}','bhvs',0,'COMMERCE_CART_FRAGMENTS-mini-cart',1,'2026-03-19 16:19:04.207000',NULL)
