ndant aria-controls="navigationBarCollapse-${fragmentEntryLinkNamespace}" aria-expanded="false" aria-haspopup="listbox" aria-label="${languageUtil.format(locale, ''current-x'', [''selection''])}:" class="collapsed navbar-toggler navbar-toggler-link" data-toggle="collapse" role="combobox">\u000a\u0009\u0009\u0009<span class="navbar-text-truncate">${languageUtil.get(locale, "multishipping")}</span>\u000a\u0009\u0009\u0009<span class="icon-caret-bottom"></span>\u000a\u0009\u0009</button>\u000a\u000a\u0009\u0009<div class="collapse navbar-collapse" id="navigationBarCollapse-${fragmentEntryLinkNamespace}">\u000a\u0009\u0009\u0009<ul class="navbar-nav" role="tablist">\u000a\u0009\u0009\u0009\u0009<li class="nav-item" role="presentation">\u000a\u0009\u0009\u0009\u0009\u0009<button aria-controls="tabPanel1-${fragmentEntryLinkNamespace}" aria-selected="false" class="nav-link" data-fragment-namespace="${fragmentEntryLinkNamespace}" id="tab1-${fragmentEntryLinkNamespace}" role="tab">\u000a\u0009\u0009\u0009\u0009\u0009\u0009<span class="navbar-text-truncate" data-lfr-editable-id="title1" data-lfr-editable-type="text" data-lfr-priority="1" tabindex="-1">\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009${languageUtil.get(locale, "list")}\u000a\u0009\u0009\u0009\u0009\u0009\u0009</span>\u000a\u0009\u0009\u0009\u0009\u0009</button>\u000a\u000a\u0009\u0009\u0009\u0009\u0009<button aria-controls="tabPanel2-${fragmentEntryLinkNamespace}" aria-selected="false" class="nav-link" data-fragment-namespace="${fragmentEntryLinkNamespace}" id="tab2-${fragmentEntryLinkNamespace}" role="tab">\u000a\u0009\u0009\u0009\u0009\u0009\u0009<span class="navbar-text-truncate" data-lfr-editable-id="title2" data-lfr-editable-type="text" data-lfr-priority="1" tabindex="-1">\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009${languageUtil.get(locale, "multishipping")}\u000a\u0009\u0009\u0009\u0009\u0009\u0009</span>\u000a\u0009\u0009\u0009\u0009\u0009</button>\u000a\u0009\u0009\u0009\u0009</li>\u000a\u0009\u0009\u0009</ul>\u000a\u0009\u0009</div>\u000a\u0009</nav>\u000a\u000a\u0009<div class="tab-panel">\u000a\u0009\u0009<div aria-labelledby="tab1-${fragmentEntryLinkNamespace}" class="d-none tab-panel-item" data-fragment-namespace="${fragmentEntryLinkNamespace}" id="tabPanel1-${fragmentEntryLinkNamespace}" role="tabpanel" tabindex="0">\u000a\u0009\u0009\u0009<lfr-drop-zone data-lfr-drop-zone-id="1" data-lfr-priority="1"></lfr-drop-zone>\u000a\u0009\u0009</div>\u000a\u000a\u0009\u0009[#if isMultishippingEnabled || (layouts?size > 0) || (layoutMode == "edit")]\u000a\u0009\u0009\u0009<div aria-labelledby="tab2-${fragmentEntryLinkNamespace}" class="d-none tab-panel-item" data-fragment-namespace="${fragmentEntryLinkNamespace}" id="tabPanel2-${fragmentEntryLinkNamespace}" role="tabpanel" tabindex="0">\u000a\u0009\u0009\u0009\u0009<lfr-drop-zone data-lfr-drop-zone-id="2" data-lfr-priority="2"></lfr-drop-zone>\u000a\u0009\u0009\u0009</div>\u000a\u0009\u0009[/#if]\u000a\u0009</div>\u000a</div>','/* eslint-disable no-undef */\u000a\u000a/**\u000a * SPDX-FileCopyrightText: (c) 2000 Liferay, Inc. https://liferay.com\u000a * SPDX-License-Identifier: LGPL-2.1-or-later OR LicenseRef-Liferay-DXP-EULA-2.0.0-2023-06\u000a */\u000a\u000aconst dropdown = fragmentElement.querySelector(''.navbar-collapse'');\u000aconst dropdownButton = fragmentElement.querySelector(''.navbar-toggler-link'');\u000aconst editMode = layoutMode === ''edit'';\u000aconst persistedTabKey = ''tabsFragment_'' + fragmentNamespace + ''_persistedTabId'';\u000a\u000aconst tabItems = [].slice.call(\u000a\u0009fragmentElement.querySelectorAll(\u000a\u0009\u0009''[data-fragment-namespace="'' + fragmentNamespace + ''"].nav-link''\u000a\u0009)\u000a);\u000a\u000aconst tabPanelItems = [].slice.call(\u000a\u0009fragmentElement.querySelectorAll(\u000a\u0009\u0009''[data-fragment-namespace="'' + fragmentNamespace + ''"].tab-panel-item''\u000a\u0009)\u000a);\u000a\u000aconst persistedTab = (function () {\u000a\u0009if (!configuration.persistSelectedTab) {\u000a\u0009\u0009let persistedId;\u000a\u000a\u0009\u0009return {\u000a\u0009\u0009\u0009getId() {\u000a\u0009\u0009\u0009\u0009return persistedId;\u000a\u0009\u0009\u0009},\u000a\u000a\u0009\u0009\u0009setId(nextId) {\u000a\u0009\u0009\u0009\u0009persistedId = nextId;\u000a\u0009\u0009\u0009},\u000a\u0009\u0009};\u000a\u0009}\u000a\u000a\u0009return {\u000a\u0009\u0009getId() {\u000a\u0009\u0009\u0009return Number(\u000a\u0009\u0009\u0009\u0009Liferay.Util.SessionStorage.getItem(\u000a\u0009\u0009\u0009\u0009\u0009persistedTabKey,\u000a\u0009\u0009\u0009\u0009\u0009Liferay.Util.SessionStorage.TYPES.PERSONALIZATION\u000a\u0009\u0009\u0009\u0009)\u000a\u0009\u0009\u0009);\u000a\u0009\u0009},\u000a\u000a\u0009\u0009setId(id) {\u000a\u0009\u0009\u0009Liferay.Util.SessionStorage.setItem(\u000a\u0009\u0009\u0009\u0009persistedTabKey,\u000a\u0009\u0009\u0009\u0009id,\u000a\u0009\u0009\u0009\u0009Liferay.Util.SessionStorage.TYPES.PERSONALIZATION\u000a\u0009\u0009\u0009);\u000a\u0009\u0009},\u000a\u0009};\u000a})();\u000a\u000afunction activeTab(item) {\u000a\u0009const getAriaLabel = () => {\u000a\u0009\u0009const label = dropdownButton.getAttribute(''aria-label'');\u000a\u0009\u0009const [currentSelectionText] = label.split('':'');\u000a\u000a\u0009\u0009return `${currentSelectionText}: ${item.textContent.trim()}`;\u000a\u0009};\u000a\u000a\u0009tabItems.forEach((tabItem) => {\u000a\u0009\u0009tabItem.setAttribute(''aria-selected'', false);\u000a\u0009\u0009tabItem.classList.remove(''active'');\u000a\u0009});\u000a\u000a\u0009dropdownButton.setAttribute(''aria-label'', getAriaLabel());\u000a\u0009item.setAttribute(''aria-selected'', true);\u000a\u0009item.classList.add(''active'');\u000a}\u000a\u000afunction activeTabPanel(item) {\u000a\u0009tabPanelItems.forEach((tabPanelItem) => {\u000a\u0009\u0009if (!tabPanelItem.classList.contains(''d-none'')) {\u000a\u0009\u0009\u0009tabPanelItem.classList.add(''d-none'');\u000a\u0009\u0009}\u000a\u0009});\u000a\u000a\u0009item.classList.remove(''d-none'');\u000a}\u000a\u000afunction handleDropdown(event, item) {\u000a\u0009event.preventDefault();\u000a\u0009dropdown.classList.toggle(''show'');\u000a\u000a\u0009const ariaExpanded = dropdownButton.getAttribute(''aria-expanded'');\u000a\u000a\u0009dropdownButton.setAttribute(\u000a\u0009\u0009''aria-expanded'',\u000a\u0009\u0009ariaExpanded === ''false'' ? true : false\u000a\u0009);\u000a\u000a\u0009if (item) {\u000a\u0009\u0009handleDropdownButtonName(item);\u000a\u0009}\u000a}\u000a\u000afunction handleDropdownButtonName(item) {\u000a\u0009const tabText =\u000a\u0009\u0009item.querySelector(''lfr-editable'') ||\u000a\u0009\u0009item.querySelector(''.navbar-text-truncate'');\u000a\u000a\u0009if (tabText) {\u000a\u0009\u0009dropdownButton.querySelector(''.navbar-text-truncate'').innerHTML =\u000a\u0009\u0009\u0009tabText.textContent;\u000a\u0009}\u000a}\u000a\u000afunction main() {\u000a\u0009const tabItemId = tabItems[persistedTab.getId()] ? persistedTab.getId() : 0;\u000a\u000a\u0009tabItems.forEach((item, index) => {\u000a\u0009\u0009item.addEventListener(''click'', (event) => {\u000a\u0009\u0009\u0009openTabPanel(event, index);\u000a\u000a\u0009\u0009\u0009dropdownButton.focus();\u000a\u0009\u0009});\u000a\u0009});\u000a\u000a\u0009dropdownButton.addEventListener(''click'', (event) => {\u000a\u0009\u0009handleDropdown(event);\u000a\u0009});\u000a\u000a\u0009activeTab(tabItems[tabItemId]);\u000a\u0009activeTabPanel(tabPanelItems[tabItemId]);\u000a\u0009handleDropdownButtonName(tabItems[tabItemId]);\u000a}\u000a\u000afunction openTabPanel(event, i) {\u000a\u0009const currentTarget = event.currentTarget;\u000a\u0009const target = event.target;\u000a\u000a\u0009const isEditable =\u000a\u0009\u0009target.hasAttribute(''data-lfr-editable-id'') ||\u000a\u0009\u0009target.hasAttribute(''contenteditable'');\u000a\u000a\u0009const dropdownIsOpen = JSON.parse(\u000a\u0009\u0009dropdownButton.getAttribute(''aria-expanded'')\u000a\u0009);\u000a\u000a\u0009if (!isEditable || !editMode) {\u000a\u0009\u0009if (dropdownIsOpen) {\u000a\u0009\u0009\u0009handleDropdown(event, currentTarget);\u000a\u0009\u0009}\u000a\u0009\u0009else {\u000a\u0009\u0009\u0009handleDropdownButtonName(currentTarget);\u000a\u0009\u0009}\u000a\u000a\u0009\u0009currentTarget.focus();\u000a\u000a\u0009\u0009activeTab(currentTarget, i);\u000a\u0009\u0009activeTabPanel(tabPanelItems[i]);\u000a\u0009\u0009persistedTab.setId(i);\u000a\u000a\u0009\u0009Liferay.fire(''tabsFragment:activePanel'', {panel: tabPanelItems[i]});\u000a\u0009}\u000a}\u000a\u000amain();','0','','code',0,'0','0',1,'',NULL,0,20122,'Clarity Admin','2025-10-03 13:39:36.000000')
INSERT INTO FRAGMENTENTRY VALUES(1,0,'97771b22-a92d-6356-ddec-65b215cc4090','97771b22-a92d-6356-ddec-65b215cc4090',-902,'1',902,69131,16796623585306,20122,'Clarity Admin','2025-11-02 13:59:52.000000','2025-11-02 13:59:52.000000',69358,'personal-bar','User Personal Bar','.commerce-liferay-sign-in .user-full-name {\u000a    font-size: small;\u000a    font-weight: var(--font-weight-semi-bold);\u000a    width: 10rem;\u000a}','<div class="align-items-center commerce-liferay-sign-in d-flex">\u000a\u0009\u0009[@liferay.user_personal_bar /]\u000a\u000a\u0009\u0009<div class="user-full-name">\u000a\u0009\u0009\u0009<span class="px-3 text-truncate">\u000a\u0009\u0009\u0009\u0009${user.getFullName()}\u000a\u0009\u0009\u0009</span>\u000a\u0009\u0009</div>\u000a\u0009</div>\u000a</div>','/**\u000a * SPDX-FileCopyrightText: (c) 2000 Liferay, Inc. https://liferay.com\u000a * SPDX-License-Identifier: LGPL-2.1-or-later OR LicenseRef-Liferay-DXP-EULA-2.0.0-2023-06\u000a */\u000a\u000aconst setGuestOrderEnabled = ({guestOrderEnabled}) => {\u000a\u0009const signInButton = document.querySelector(''button.sign-in'');\u000a\u000a\u0009if (signInButton && guestOrderEnabled) {\u000a\u0009\u0009const clonedSignInButton = signInButton.cloneNode(true);\u000a\u000a\u0009\u0009signInButton.parentElement.replaceChild(\u000a\u0009\u0009\u0009clonedSignInButton,\u000a\u0009\u0009\u0009signInButton\u000a\u0009\u0009);\u000a\u0009\u0009const performGuestSignIn = (event) => {\u000a\u0009\u0009\u0009event.preventDefault();\u000a\u000a\u0009\u0009\u0009window.Liferay.fire(''perform-sign-in'');\u000a\u000a\u0009\u0009\u0009return false;\u000a\u0009\u0009};\u000a\u000a\u0009\u0009clonedSignInButton.addEventListener(''click'', performGuestSignIn);\u000a\u0009}\u000a\u000a\u0009window.Liferay.detach(''guest-order-enabled'', setGuestOrderEnabled);\u000a};\u000a\u000awindow.Liferay.on(''guest-order-enabled'', setGuestOrderEnabled);','0','','code',0,'0','0',1,'',NULL,0,20122,'Clarity Admin','2025-11-02 13:59:52.000000')
INSERT INTO FRAGMENTENTRY VALUES(3,0,'3c87f6a9-fa91-bc99-6b0c-1442ed68bed9','3c87f6a9-fa91-bc99-6b0c-1442ed68bed9',-905,'1',905,69131,16796623585306,20122,'Clarity Admin','2025-11-02 13:59:52.000000','2025-11-03 18:48:43.000000',69358,'primary-navigation','Minium Primary Navigation','','[#assign\u000a\u0009branchNavItems = sourceObject.branchNavItems\u000a\u0009entries = sourceObject.navItems\u000a/]\u000a\u000a[#if !entries?has_content]\u000a\u0009<div class="alert alert-info">\u000a\u0009\u0009[@liferay.language key="there-are-no-menu-items-to-display" /]\u000a\u0009</div>\u000a[#else]\u000a\u0009<script id="minium-primary-navigation-data" type="application/ld+json">\u000a\u0009\u0009[@build_props\u000a\u0009\u0009\u0009navItems=entries\u000a\u0009\u0009/]\u000a\u0009</script>\u000a[/#if]\u000a\u000a[#macro build_props\u000a\u0009navItems\u000a]\u000a\u0009[\u000a\u0009\u0009[#list navItems as navItem]\u000a\u0009\u0009\u0009{\u000a\u0009\u0009\u0009\u0009[#if navItem.isChildSelected() || navItem.isSelected()]\u000a\u0009\u0009\u0009\u0009\u0009"active": true,\u000a\u0009\u0009\u0009\u0009[#else]\u000a\u0009\u0009\u0009\u0009\u0009"active": false,\u000a\u0009\u0009\u0009\u0009[/#if]\u000a\u0009\u0009\u0009\u0009"friendlyURL": "${navItem.getLayout().getFriendlyURL(locale)}",\u000a\u0009\u0009\u0009\u0009[#if !navItem.getChildren()?has_content]\u000a\u0009\u0009\u0009\u0009\u0009"href": "${navItem.getURL()}",\u000a\u0009\u0009\u0009\u0009[#else]\u000a\u0009\u0009\u0009\u0009\u0009"items": [@build_props navItems=navItem.getChildren() /],\u000a\u0009\u0009\u0009\u0009[/#if]\u000a\u0009\u0009\u0009\u0009"id": "${navItem.getLayoutId()}",\u000a\u0009\u0009\u0009\u0009"label": "${navItem.getName()}"\u000a\u0009\u0009\u0009}\u000a\u000a\u0009\u0009\u0009[#if navItem?has_next]\u000a\u0009\u0009\u0009\u0009,\u000a\u0009\u0009\u0009[/#if]\u000a\u0009\u0009[/#list]\u000a\u0009]\u000a[/#macro]','/**\u000a * SPDX-FileCopyrightText: (c) 2000 Liferay, Inc. https://liferay.com\u000a * SPDX-License-Identifier: LGPL-2.1-or-later OR LicenseRef-Liferay-DXP-EULA-2.0.0-2023-06\u000a */\u000a\u000aimport MiniumPrimaryNavigation from ''minium-primary-navigation'';\u000aimport React from ''react'';\u000aimport ReactDOM from ''react-dom'';\u000a\u000aconst navigationConfigurationContent = fragmentElement.querySelector(\u000a\u0009''#minium-primary-navigation-data''\u000a).innerHTML;\u000a\u000aReactDOM.render(\u000a\u0009React.createElement(MiniumPrimaryNavigation, {\u000a\u0009\u0009entries: JSON.parse(navigationConfigurationContent),\u000a\u0009\u0009spritemap: Liferay.Icons.spritemap,\u000a\u0009}),\u000a\u0009fragmentElement\u000a);','0','{\u000a\u0009"fieldSets": [\u000a\u0009\u0009{\u000a\u0009\u0009\u0009"fields": [\u000a\u0009\u0009\u0009\u0009{\u000a\u0009\u0009\u0009\u0009\u0009"label": "source",\u000a\u0009\u0009\u0009\u0009\u0009"name": "source",\u000a\u0009\u0009\u0009\u0009\u0009"type": "navigationMenuSelector"\u000a\u0009\u0009\u0009\u0009}\u000a\u0009\u0009\u0009]\u000a\u0009\u0009}\u000a\u0009]\u000a}','code',0,'0','0',1,'',NULL,0,20122,'Clarity Admin','2025-11-02 13:59:52.000000')
INSERT INTO FRAGMENTENTRY VALUES(10,0,'11d857b0-9cdf-f7e0-2a9a-7373f9b995a0','11d857b0-9cdf-f7e0-2a9a-7373f9b995a0',-910,'1',910,69131,16796623585306,20122,'Clarity Admin','2025-11-02 14:16:26.000000','2025-11-26 12:44:05.000000',79236,'sales-order-table','Sales Order Table','.fragment_469 {\u000a}\u000a\u000ah6 {\u000a\u0009color: #8B9393; /*neutral-05*/\u000a}\u000a\u000a.fragment_469.sales-order-table .status-label {\u000a\u0009border-radius:5px;\u000a\u0009font-size:80%;\u000a\u0009color:white;\u000a\u0009font-weight:600;\u000a\u0009padding: 3px;\u000a\u0009text-align: center;\u000a}\u000a\u000a.fragment_469 .table thead {\u000a\u0009background-color: var(--color-brand-primary);\u000a}\u000a\u000a.fragment_469 .table th {\u000a\u0009color: var(--color-action-neutral-inverted);\u000a}\u000a\u000a.fragment_469 .table-rounded-container {\u000a    border-radius: var(--card-border-radius);    \u000a    overflow: hidden; \u000a    border: 1px solid #dee2e6; \u000a}\u000a\u000a.fragment_469 .table-rounded-container table {\u000a    margin-bottom: 0;\u000a}','<div class="fragment_469 sales-order-table">\u000a\u0009<div class="section-heading-container mt-2">\u000a\u0009<h6 class="font-weight-bold text-uppercase" data-lfr-editable-id="section-heading-fragment" data-lfr-editable-type="text">\u000a\u0009\u0009Recent Orders\u000a\u0009</h6>\u000a</div>\u000a\u0009<div class="table-rounded-container">\u000a\u0009<table class="table table-striped">\u000a\u0009\u0009<thead>\u000a\u0009\u0009\u0009<tr>\u000a\u0009\u0009\u0009\u0009<th class="text-center" scope="col">Order #</th>\u000a\u0009\u0009\u0009\u0009<th class="text-center" scope="col">Account</th>\u000a\u0009\u0009\u0009\u0009<th class="text-center" scope="col">Order Fullfilment</th>\u000a\u0009\u0009\u0009\u0009<th class="text-center" scope="col">Payment</th>\u000a\u0009\u0009\u0009</tr>\u000a\u0009\u0009</thead>\u000a\u0009\u0009<tbody></tbody>\u000a\u0009</table>\u000a\u0009</div>\u000a</div>','function displayOrders() {\u000a\u0009const editMode = false;\u000a\u0009if(editMode) return;\u000a\u000a\u0009if(!Liferay.CommerceContext) {\u000a\u0009\u0009console.log("No Commerce Context");\u000a\u0009\u0009return;\u000a\u0009}\u000a\u000a\u0009const graphQLQuery = `\u000a\u0009\u0009query placedOrders($accountId:Long, $channelId:Long) {\u000a\u0009\u0009\u0009channelAccountPlacedOrders(\u000a\u0009\u0009\u0009\u0009accountId:$accountId,\u000a\u0009\u0009\u0009\u0009channelId:$channelId) \u000a\u0009\u0009\u0009{\u000a\u0009\u0009\u0009\u0009totalCount\u000a\u0009\u0009\u0009\u0009items {\u000a\u0009\u0009\u0009\u0009\u0009id\u000a\u0009\u0009\u0009\u0009\u0009accountId\u000a\u0009\u0009\u0009\u0009\u0009purchaseOrderNumber\u000a\u0009\u0009\u0009\u0009\u0009status\u000a\u0009\u0009\u0009\u0009\u0009modifiedDate\u000a\u0009\u0009\u0009\u0009\u0009paymentStatus\u000a\u0009\u0009\u0009\u0009\u0009customFields\u000a\u0009\u0009\u0009\u0009\u0009orderStatusInfo {\u000a\u0009\u0009\u0009\u0009\u0009\u0009code\u000a\u0009\u0009\u0009\u0009\u0009\u0009label\u000a\u0009\u0009\u0009\u0009\u0009}\u000a\u0009\u0009\u0009\u0009\u0009paymentStatus\u000a\u0009\u0009\u0009\u0009\u0009paymentMethod\u000a\u0009\u0009\u0009\u0009\u0009paymentStatusLabel\u000a\u0009\u0009\u0009\u0009\u0009account\u000a\u0009\u0009\u0009\u0009}\u000a\u0009\u0009\u0009}\u000a\u0009\u0009}\u000a\u0009`;\u000a\u000a\u0009let postBody = {\u000a\u0009\u0009"query": graphQLQuery,\u000a\u0009\u0009"variables": {\u000a\u0009\u0009\u0009"accountId":Liferay.CommerceContext.account.accountId,\u000a\u0009\u0009\u0009"channelId":Liferay.CommerceContext.commerceChannelId\u000a\u0009\u0009}\u000a\u0009};\u000a\u000a\u0009Liferay.Util.fetch (\u000a\u0009\u0009"/o/graphql/", \u000a\u0009\u0009{\u000a\u0009\u0009\u0009headers: {\u000a\u0009\u0009\u0009\u0009''Accept'': ''application/json'',\u000a\u0009\u0009\u0009\u0009''Content-Type'': ''application/json''\u000a\u0009\u0009\u0009},\u000a\u0009\u0009\u0009body:JSON.stringify(postBody),\u000a\u0009\u0009\u0009method: ''POST''\u000a\u0009\u0009}\u000a\u0009)\u000a\u0009.then((response) => response.json()) \u000a\u0009.then((data) => {\u000a\u0009\u0009console.log(data);\u000a\u0009\u0009\u000a\u0009\u0009const ordersList = data.data.channelAccountPlacedOrders.items;\u000a\u0009\u0009\u000a\u0009\u0009const tbodyElem = fragmentElement.querySelector(''.sales-order-table tbody'');\u000a\u000a\u0009\u0009let trElem, tdElem, tdInnerDiv;\u000a\u0009\u0009\u000a\u0009\u0009const orderAcctName = Liferay.CommerceContext.account.accountName;\u000a\u0009\u0009\u000a\u0009\u0009for(let i = 0; i < ordersList.length; i++) {\u000a\u0009\u0009\u0009trElem = document.createElement("tr");\u000a\u0009\u0009\u0009\u000a\u0009\u0009\u0009// order #\u000a\u0009\u0009\u0009tdElem = document.createElement("td");\u000a\u0009\u0009\u0009tdElem.className = ''order-nav text-center'';\u000a\u0009\u0009\u0009tdElem.innerHTML = ordersList[i].id;\u000a\u0009\u0009\u0009trElem.append(tdElem);\u000a\u000a\u0009\u0009\u0009// account for order\u000a\u0009\u0009\u0009tdElem = document.createElement("td");\u000a\u0009\u0009\u0009tdElem.className = ''text-center'';\u000a\u0009\u0009\u0009tdElem.innerHTML = ordersList[i].account;\u000a\u0009\u0009\u0009trElem.append(tdElem);\u000a\u000a\u0009\u0009\u0009// order status\u000a\u0009\u0009\u0009tdElem = document.createElement("td");\u000a\u0009\u0009\u0009tdInnerDiv = document.createElement("div");\u000a\u0009\u0009\u0009tdElem.append(tdInnerDiv);\u000a\u0009\u0009\u0009tdInnerDiv.classList.add("status-label");\u000a\u0009\u0009\u0009switch(ordersList[i].orderStatusInfo.code) {\u000a\u0009\u0009\u0009\u0009case 14: // partially-shipped\u000a\u0009\u0009\u0009\u0009\u0009tdInnerDiv.classList.add("bg-warning");\u000a\u0009\u0009\u0009\u0009\u0009break;\u000a\u0009\u0009\u0009\u0009case 1: // pending\u000a\u0009\u0009\u0009\u0009\u0009tdInnerDiv.classList.add("bg-primary");\u000a\u0009\u0009\u0009\u0009\u0009break;\u000a\u0009\u0009\u0009\u0009case 0: // completed\u000a\u0009\u0009\u0009\u0009\u0009tdInnerDiv.classList.add("bg-success");\u000a\u0009\u0009\u0009\u0009\u0009break;\u000a\u0009\u0009\u0009\u0009case 15: // shipped\u000a\u0009\u0009\u0009\u0009\u0009tdInnerDiv.classList.add("bg-info");\u000a\u0009\u0009\u0009\u0009\u0009break;\u000a\u0009\u0009\u0009\u0009default:\u000a\u0009\u0009\u0009\u0009\u0009tdInnerDiv.classList.add("bg-dark");\u000a\u0009\u0009\u0009\u0009\u0009break;\u000a\u0009\u0009\u0009}\u000a\u0009\u0009\u0009tdInnerDiv.innerHTML = ordersList[i].orderStatusInfo.label.toUpperCase();\u000a\u0009\u0009\u0009trElem.append(tdElem);\u000a\u000a\u0009\u0009\u0009// payment status\u000a\u0009\u0009\u0009tdElem = document.createElement("td");\u000a\u0009\u0009\u0009tdInnerDiv = document.createElement("div");\u000a\u0009\u0009\u0009tdElem.append(tdInnerDiv);\u000a\u0009\u0009\u0009tdInnerDiv.classList.add("status-label");\u000a\u0009\u0009\u0009if(ordersList[i].paymentStatus == 1) {\u000a\u0009\u0009\u0009\u0009tdInnerDiv.classList.add("bg-secondary");\u000a\u0009\u0009\u0009}\u000a\u0009\u0009\u0009else if(ordersList[i].paymentStatus == 0) {\u000a\u0009\u0009\u0009\u0009tdInnerDiv.classList.add("bg-success");\u000a\u0009\u0009\u0009}\u000a\u0009\u0009\u0009else {\u000a\u0009\u0009\u0009\u0009tdInnerDiv.classList.add("bg-warning");\u000a\u0009\u0009\u0009}\u000a\u0009\u0009\u0009tdInnerDiv.innerHTML = ordersList[i].paymentStatusLabel.toUpperCase();\u000a\u0009\u0009\u0009trElem.append(tdElem);\u000a\u000a\u0009\u0009\u0009tbodyElem.append(trElem);\u000a\u0009\u0009}\u000a\u0009});\u000a}\u000a\u000adisplayOrders();','0','{\u000a\u0009"fieldSets": [\u000a\u0009]\u000a}','code',0,'0','0',1,'',NULL,0,20122,'Clarity Admin','2025-11-02 14:16:26.000000')
INSERT INTO FRAGMENTENTRY VALUES(15,0,'239f2ad9-911d-508f-2a3d-a58e082f5443','239f2ad9-911d-508f-2a3d-a58e082f5443',-912,'1',912,69131,16796623585306,20122,'Clarity Admin','2025-11-02 14:16:40.000000','2025-12-13 04:25:24.000000',79236,'shipments-table','Shipments Table','.fragment_477 {\u000a}\u000a\u000a.fragment_477 h6 {\u000a\u0009color: #8B9393; /*neutral-05*/\u000a}\u000a\u000a.fragment_477 .table thead {\u000a\u0009background-color: var(--color-brand-primary);\u000a}\u000a\u000a.fragment_477 .table th {\u000a\u0009color: var(--color-action-neutral-inverted);\u000a}\u000a\u000a.fragment_477 .table-rounded-container {\u000a    border-radius: var(--card-border-radius);    \u000a    overflow: hidden; \u000a    border: 1px solid #dee2e6; \u000a}\u000a\u000a.fragment_477 .table-rounded-container table {\u000a    margin-bottom: 0;\u000a}','<div class="fragment_477 shipments-table">\u000a\u0009<div class="section-heading-container mt-2">\u000a\u0009<h6 class="font-weight-bold text-uppercase" data-lfr-editable-id="section-heading-fragment" data-lfr-editable-type="text">\u000a\u0009\u0009Recent Shipments\u000a\u0009</h6>\u000a</div>\u000a\u0009<div class="table-rounded-container">\u000a\u0009<table class="table table-striped">\u000a\u0009\u0009<thead>\u000a\u0009\u0009\u0009<tr>\u000a\u0009\u0009\u0009\u0009<th scope="col">ID</th>\u000a\u0009\u0009\u0009\u0009<th scope="col">Carrier</th>\u000a\u0009\u0009\u0009\u0009<th scope="col">Ship Date</th>\u000a\u0009\u0009\u0009\u0009<th scope="col">Status</th>\u000a\u0009\u0009\u0009\u0009<th scope="col">Tracking #</th>\u000a\u0009\u0009\u0009</tr>\u000a\u0009\u0009</thead>\u000a\u0009\u0009<tbody></tbody>\u000a\u0009</table>\u000a\u0009</div>\u000a</div>','function displayShipments() {\u000a\u0009const editMode = false;\u000a\u0009if(editMode) return;\u000a\u000a\u0009Liferay.Util.fetch (\u000a\u0009\u0009"/o/headless-commerce-admin-shipment/v1.0/shipments", \u000a\u0009\u0009{\u000a\u0009\u0009\u0009headers: {\u000a\u0009\u0009\u0009\u0009''Accept'': ''application/json'',\u000a\u0009\u0009\u0009\u0009''Content-Type'': ''application/json''\u000a\u0009\u0009\u0009},\u000a\u0009\u0009\u0009method: ''GET''\u000a\u0009\u0009}\u000a\u0009)\u000a\u0009.then((response) => response.json()) \u000a\u0009.then((data) => {\u000a\u0009\u0009console.log(data);\u000a\u0009\u0009\u000a\u0009\u0009const patagoniaAcct = 44258;\u000a\u0009\u0009const smithsonianAcct = 45273;\u000a\u0009\u0009\u000a\u0009\u0009const shipmentList = data.items;\u000a\u0009\u0009const tbodyElem = fragmentElement.querySelector(''.shipments-table tbody'');\u000a\u000a\u0009\u0009let trElem, tdElem, tdInnerDiv, trackingAnchor;\u000a\u0009\u0009\u000a\u0009\u0009let shippingRecord, shipDateStr, statusCode, shipToStr;\u000a\u0009\u0009for(let i = 0; i < shipmentList.length; i++) {\u000a\u0009\u0009\u0009// Stop after 7\u000a\u0009\u0009\u0009if(i > 6) {\u000a\u0009\u0009\u0009\u0009return;\u000a\u0009\u0009\u0009}\u000a\u0009\u0009\u0009\u000a\u0009\u0009\u0009shippingRecord = shipmentList[i];\u000a\u0009\u0009\u0009statusCode = shippingRecord.status.code;\u000a\u0009\u0009\u0009\u000a\u0009\u0009\u0009trElem = document.createElement("tr");\u0009\u0009\u000a\u0009\u0009\u0009\u000a\u0009\u0009\u0009tdElem = document.createElement("td");\u000a\u0009\u0009\u0009tdElem.innerHTML = shippingRecord.id;\u000a\u0009\u0009\u0009trElem.append(tdElem);\u000a\u000a\u0009\u0009\u0009tdElem = document.createElement("td");\u000a\u0009\u0009\u0009if(statusCode != 0) {\u000a\u0009\u0009\u0009\u0009tdElem.innerHTML = shippingRecord.carrier;\u000a\u0009\u0009\u0009}\u000a\u0009\u0009\u0009trElem.append(tdElem);\u000a\u000a\u0009\u0009\u0009shipDateStr = "";\u000a\u0009\u0009\u0009if(statusCode != 0) {\u000a\u0009\u0009\u0009\u0009if(shippingRecord.shippingDate.endsWith("Z")) {\u000a\u0009\u0009\u0009\u0009\u0009shipDateStr = shippingRecord.shippingDate.substring(0, shippingRecord.shippingDate.length-1);\u000a\u0009\u0009\u0009\u0009}\u000a\u0009\u0009\u0009\u0009\u000a\u0009\u0009\u0009\u0009shipDateStr = (new Date(shipDateStr)).toLocaleDateString(''en-us'', { year:"numeric", month:"short", day:"numeric"}) \u000a\u0009\u0009\u0009}\u000a\u000a\u0009\u0009\u0009tdElem = document.createElement("td");\u000a\u0009\u0009\u0009tdElem.innerHTML = shipDateStr;\u000a\u0009\u0009\u0009trElem.append(tdElem);\u000a\u000a\u000a\u0009\u0009\u0009tdElem = document.createElement("td");\u000a\u0009\u0009\u0009tdElem.innerHTML = shippingRecord.status.label_i18n;\u000a\u0009\u0009\u0009trElem.append(tdElem);\u000a\u000a\u0009\u0009\u0009tdElem = document.createElement("td");\u000a\u0009\u0009\u0009trackingAnchor = document.createElement("a");\u000a\u0009\u0009\u0009trackingAnchor.setAttribute("href", shippingRecord.trackingURL);\u000a\u0009\u0009\u0009trackingAnchor.innerHTML = shippingRecord.trackingNumber;\u000a\u0009\u0009\u0009tdElem.append(trackingAnchor);\u000a\u0009\u0009\u0009trElem.append(tdElem);\u000a\u000a\u0009\u0009\u000a\u0009\u0009\u0009tbodyElem.append(trElem);\u000a\u000a\u0009\u0009}\u000a\u0009\u0009\u0009\u000a\u0009\u0009\u0009\u000a\u000a\u0009});\u0009\u000a}\u000a\u000adisplayShipments();\u000a\u000a','0','{\u000a\u0009"fieldSets": [\u000a\u0009]\u000a}','code',0,'0','0',1,'',NULL,0,20122,'Clarity Admin','2025-11-02 14:16:40.000000')
COMMIT
