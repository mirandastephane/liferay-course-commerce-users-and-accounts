INSERT INTO FRAGMENTENTRY VALUES(15,0,'239f2ad9-911d-508f-2a3d-a58e082f5443','239f2ad9-911d-508f-2a3d-a58e082f5443',-912,'1',912,69131,16796623585306,20122,'Clarity Admin','2025-11-02 14:16:40.000000','2025-12-13 04:25:24.000000',79236,'shipments-table','Shipments Table','.fragment_477 {\u000a}\u000a\u000a.fragment_477 h6 {\u000a\u0009color: #8B9393; /*neutral-05*/\u000a}\u000a\u000a.fragment_477 .table thead {\u000a\u0009background-color: var(--color-brand-primary);\u000a}\u000a\u000a.fragment_477 .table th {\u000a\u0009color: var(--color-action-neutral-inverted);\u000a}\u000a\u000a.fragment_477 .table-rounded-container {\u000a    border-radius: var(--card-border-radius);    \u000a    overflow: hidden; \u000a    border: 1px solid #dee2e6; \u000a}\u000a\u000a.fragment_477 .table-rounded-container table {\u000a    margin-bottom: 0;\u000a}','<div class="fragment_477 shipments-table">\u000a\u0009<div class="section-heading-container mt-2">\u000a\u0009<h6 class="font-weight-bold text-uppercase" data-lfr-editable-id="section-heading-fragment" data-lfr-editable-type="text">\u000a\u0009\u0009Recent Shipments\u000a\u0009</h6>\u000a</div>\u000a\u0009<div class="table-rounded-container">\u000a\u0009<table class="table table-striped">\u000a\u0009\u0009<thead>\u000a\u0009\u0009\u0009<tr>\u000a\u0009\u0009\u0009\u0009<th scope="col">ID</th>\u000a\u0009\u0009\u0009\u0009<th scope="col">Carrier</th>\u000a\u0009\u0009\u0009\u0009<th scope="col">Ship Date</th>\u000a\u0009\u0009\u0009\u0009<th scope="col">Status</th>\u000a\u0009\u0009\u0009\u0009<th scope="col">Tracking #</th>\u000a\u0009\u0009\u0009</tr>\u000a\u0009\u0009</thead>\u000a\u0009\u0009<tbody></tbody>\u000a\u0009</table>\u000a\u0009</div>\u000a</div>','function displayShipments() {\u000a\u0009const editMode = false;\u000a\u0009if(editMode) return;\u000a\u000a\u0009Liferay.Util.fetch (\u000a\u0009\u0009"/o/headless-commerce-admin-shipment/v1.0/shipments", \u000a\u0009\u0009{\u000a\u0009\u0009\u0009headers: {\u000a\u0009\u0009\u0009\u0009''Accept'': ''application/json'',\u000a\u0009\u0009\u0009\u0009''Content-Type'': ''application/json''\u000a\u0009\u0009\u0009},\u000a\u0009\u0009\u0009method: ''GET''\u000a\u0009\u0009}\u000a\u0009)\u000a\u0009.then((response) => response.json()) \u000a\u0009.then((data) => {\u000a\u0009\u0009console.log(data);\u000a\u0009\u0009\u000a\u0009\u0009const patagoniaAcct = 44258;\u000a\u0009\u0009const smithsonianAcct = 45273;\u000a\u0009\u0009\u000a\u0009\u0009const shipmentList = data.items;\u000a\u0009\u0009const tbodyElem = fragmentElement.querySelector(''.shipments-table tbody'');\u000a\u000a\u0009\u0009let trElem, tdElem, tdInnerDiv, trackingAnchor;\u000a\u0009\u0009\u000a\u0009\u0009let shippingRecord, shipDateStr, statusCode, shipToStr;\u000a\u0009\u0009for(let i = 0; i < shipmentList.length; i++) {\u000a\u0009\u0009\u0009// Stop after 7\u000a\u0009\u0009\u0009if(i > 6) {\u000a\u0009\u0009\u0009\u0009return;\u000a\u0009\u0009\u0009}\u000a\u0009\u0009\u0009\u000a\u0009\u0009\u0009shippingRecord = shipmentList[i];\u000a\u0009\u0009\u0009statusCode = shippingRecord.status.code;\u000a\u0009\u0009\u0009\u000a\u0009\u0009\u0009trElem = document.createElement("tr");\u0009\u0009\u000a\u0009\u0009\u0009\u000a\u0009\u0009\u0009tdElem = document.createElement("td");\u000a\u0009\u0009\u0009tdElem.innerHTML = shippingRecord.id;\u000a\u0009\u0009\u0009trElem.append(tdElem);\u000a\u000a\u0009\u0009\u0009tdElem = document.createElement("td");\u000a\u0009\u0009\u0009if(statusCode != 0) {\u000a\u0009\u0009\u0009\u0009tdElem.innerHTML = shippingRecord.carrier;\u000a\u0009\u0009\u0009}\u000a\u0009\u0009\u0009trElem.append(tdElem);\u000a\u000a\u0009\u0009\u0009shipDateStr = "";\u000a\u0009\u0009\u0009if(statusCode != 0) {\u000a\u0009\u0009\u0009\u0009if(shippingRecord.shippingDate.endsWith("Z")) {\u000a\u0009\u0009\u0009\u0009\u0009shipDateStr = shippingRecord.shippingDate.substring(0, shippingRecord.shippingDate.length-1);\u000a\u0009\u0009\u0009\u0009}\u000a\u0009\u0009\u0009\u0009\u000a\u0009\u0009\u0009\u0009shipDateStr = (new Date(shipDateStr)).toLocaleDateString(''en-us'', { year:"numeric", month:"short", day:"numeric"}) \u000a\u0009\u0009\u0009}\u000a\u000a\u0009\u0009\u0009tdElem = document.createElement("td");\u000a\u0009\u0009\u0009tdElem.innerHTML = shipDateStr;\u000a\u0009\u0009\u0009trElem.append(tdElem);\u000a\u000a\u000a\u0009\u0009\u0009tdElem = document.createElement("td");\u000a\u0009\u0009\u0009tdElem.innerHTML = shippingRecord.status.label_i18n;\u000a\u0009\u0009\u0009trElem.append(tdElem);\u000a\u000a\u0009\u0009\u0009tdElem = document.createElement("td");\u000a\u0009\u0009\u0009trackingAnchor = document.createElement("a");\u000a\u0009\u0009\u0009trackingAnchor.setAttribute("href", shippingRecord.trackingURL);\u000a\u0009\u0009\u0009trackingAnchor.innerHTML = shippingRecord.trackingNumber;\u000a\u0009\u0009\u0009tdElem.append(trackingAnchor);\u000a\u0009\u0009\u0009trElem.append(tdElem);\u000a\u000a\u0009\u0009\u000a\u0009\u0009\u0009tbodyElem.append(trElem);\u000a\u000a\u0009\u0009}\u000a\u0009\u0009\u0009\u000a\u0009\u0009\u0009\u000a\u000a\u0009});\u0009\u000a}\u000a\u000adisplayShipments();\u000a\u000a','0','{\u000a\u0009"fieldSets": [\u000a\u0009]\u000a}','code',0,'0','0',1,'',NULL,0,20122,'Clarity Admin','2025-11-02 14:16:40.000000')
COMMIT
